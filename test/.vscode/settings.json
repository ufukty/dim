{
  "[go]": {
    "dim.rules": [
      {
        "flags": "gs",
        "opacity": "mid",
        "pattern": "if\\s+err != nil\\s*{(?:(?:[^{}]|\\n)*{(?:[^}]|\\n)*})?(?:[^}]|\\n)*}"
      }
    ]
  },
  "[http]": {
    "dim.rules": [
      {
        "pattern": ".*\\$.*"
      },
      {
        "pattern": "###"
      }
    ]
  },
  "[javascript]": {
    "dim.rules": [
      {
        "pattern": "(?:announce|logger\\.\\w+)\\([^\\)]*(?:\\([^\\)]*\\))?[^\\)]*\\);", // allows 2-level nesting of parentheses
        "flags": "gs"
      }
    ]
  },
  "[json]": {
    "dim.rules": [
      {
        "pattern": ".*\\$.*" // lines like: $schema, $url
      }
    ]
  },
  "dim.defaultFlags": "g",
  "dim.defaultOpacityTier": "min",
  "dim.rules": [
    {
      "opacity": "max",
      "flags": "gs",
      "pattern": "//[^\\n]*(?:\\n\\s*//[^\\n]*)*" // comment groups
    }
  ],
  "dim.valueForMaxTier": 0.4,
  "dim.valueForMidTier": 0.3,
  "dim.valueForMinTier": 0.2,
  "dim.updatePeriod": 10
}